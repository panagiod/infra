# Example Argo CD Application — copy into applications.yaml when your app repo exists.
#
# 1. Replace MYAPP with your application name (must match deploy/ namespace).
# 2. Replace repo URL and path with your app repository.
# 3. Insert AFTER platform apps in gitops-install-order.sh (and Kind smoke waves).
# 4. Do not enable until a container image is published (GHCR or other registry).
#
# -----------------------------------------------------------------------------
# MYAPP — Application workload (separate Git repo)
# -----------------------------------------------------------------------------
# apiVersion: argoproj.io/v1alpha1
# kind: Application
# metadata:
#   name: myapp
#   namespace: argocd
#   labels:
#     infra.platform/git-source: "true"
#   finalizers:
#     - resources-finalizer.argocd.argoproj.io
# spec:
#   project: default
#   source:
#     repoURL: https://github.com/panagiod/myapp
#     targetRevision: main
#     path: deploy/overlays/staging
#   destination:
#     server: https://kubernetes.default.svc
#     namespace: myapp
#   syncPolicy:
#     automated:
#       prune: true
#       selfHeal: true
#     syncOptions:
#       - CreateNamespace=true
