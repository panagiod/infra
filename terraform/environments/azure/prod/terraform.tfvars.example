azure_region        = "westeurope"
resource_group_name = "infra-prod-rg"
cluster_name        = "infra-prod-aks"
kubernetes_version  = "1.29"

vnet_cidr       = "10.40.0.0/16"
aks_subnet_cidr = "10.40.1.0/24"

node_vm_size       = "Standard_D4s_v3"
node_desired_count = 3
node_min_count     = 3
node_max_count     = 6

gitops_repo_url        = "https://github.com/panagiod/infra"
gitops_target_revision = "main"

# Tighten before production — never use 0.0.0.0/0
api_server_authorized_ip_ranges = ["203.0.113.0/24"]

# CIS / production hardening (see docs/operations/security-baseline.md)
aks_sku_tier             = "Standard"
azure_policy_enabled     = true
enable_log_analytics     = false  # set true for Azure Monitor / audit logs (adds cost)
