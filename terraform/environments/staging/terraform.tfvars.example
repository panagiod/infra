aws_region = "us-east-1"
cluster_name = "infra-staging"
kubernetes_version = "1.29"

gitops_repo_url = "https://github.com/panagiod/infra"
gitops_target_revision = "main"

single_nat_gateway = true
node_instance_types = ["t3.large"]
node_desired_size = 2
node_min_size = 2
node_max_size = 4

# Restrict in real deployments, e.g. ["203.0.113.0/24"]
cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]
